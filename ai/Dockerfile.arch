#%USAGE: $ ./run

# FROM localhost:0/0:_
FROM archlinux:latest

SHELL ["/usr/bin/bash", "-euo", "pipefail", "-xc"]
WORKDIR /boot

ENV LANG="C.UTF-8"
RUN --mount=type=cache,id=pacman-cache,target=/var/cache/pacman/pkg,sharing=locked \
<<"EOF"
  echo "${LANG:?} UTF-8" >> /etc/locale.gen
  echo "LANG=${LANG}" > /etc/locale.conf
  locale-gen
  ln -svfT /usr/share/zoneinfo/UTC /etc/localtime
  ln -svfT bash /usr/bin/sh

  # pacman-key --init
  # pacman-key --populate archlinux
  pacman -Syu --noconfirm --needed -- \
    base-devel sudo zsh git  # base  man neovim tzdata ca-certificates curl

  # # mymirror="http://localhost:8080"
  # myarchive="https://archive.archlinux.org/repos"
  # pacman --noconfirm -Syu --needed -- reflector
  # { echo "${mymirror:+Server = $mymirror}"
  #   reflector --score 5 --protocol https
  #   printf "Server = %s/%s/\$repo/os/\$arch\n" "$myarchive" \
  #      "$(date -r /var/lib/pacman/sync/core.db +%Y/%m/%d)"
  # } > /etc/pacman.d/mirrorlist
  # pacman --noconfirm --remove --recursive --unneeded -- reflector
EOF


# MAYBE: directly use USER,HOME ?
ARG myuser=user
ARG myhome=/home/${myuser:?}
ARG myuid=1000
ARG mygid=1000
RUN --network=none <<"EOF"
  groupadd --gid "${mygid:?}" "${myuser:?}"
  useradd --create-home --home-dir "${myhome:?}" --shell "/usr/bin/zsh" --no-log-init \
    --uid "${myuid:?}" --gid "$myuser" --groups "users,wheel" --comment "$myuser@host" -- "$myuser"

  printf "%s\n" "$myuser:$myuser" | chpasswd
  install --directory --mode=750 -- /etc/sudoers.d
  # SECU:BAD: orse aur can't be installed
  echo "$myuser ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/user
  # printf "%s ALL=(ALL) NOPASSWD:SETENV: ALL\n" "$myuser" > "/etc/sudoers.d/$myuser"
  # echo "$myuser ALL=(ALL) ALL" > /etc/sudoers.d/user

  install --directory --owner="${myuser:?}" --group="$myuser" --mode=0755 -- \
    /d  # "${myhome:?}/".{config,config/opencode}  # /opt /opt/venv /opt/airydev
  # ln -sT -- /opt /d

  # find /home -exec ls -lad {} +

  # ssh-keygen -t ed25519 -C "ED_$(cat /etc/hostname)" -f /home/user/.ssh/id_ed25519
EOF


