RUN --mount=type=cache,id=pacman-cache,target=/var/cache/pacman/pkg,sharing=locked \
    --mount=type=cache,id=cargo-cache,target=${myhome:?}/.cargo,sharing=locked \
    --mount=type=bind,"src=opencode.jsonc,dst=opencode.jsonc,ro=true" \
<<"EOF"
  # HACK: precreate config file to be copied into VOLUME during its creation
  #   FIXED: prevents dangling-on-exit bind-mount over VOLUME
  # ALT: COPY --link --chmod=0644 --chown=${USER:?}:${USER:?} \
  #   opencode.jsonc  ${HOME:?}/.config/opencode/opencode.jsonc
  install -Dm644 -t ~/.config/opencode -- opencode.jsonc

  sudo pacman -S --noconfirm --needed -- bun
  pikaur --noconfirm -S opencode-bin openai-codex-bin
EOF

