USER "${myuser:?}"

ENV USER="${myuser:?}" \
  HOME="${myhome:?}" \
  SHELL="/usr/bin/zsh" \
  EDITOR="nvim" \
  PAGER="less" \
  LESS="-A -i -j.5 -M -R -S -W -z-2 -x8"
  # OR: LESS="-a -i -j6 -M -N -R -S -w -z-4 -x4"
  # PATH="/usr/local/bin:/usr/bin:/usr/sbin"
  # LD_LIBRARY_PATH="/opt/my/lib"


# TRY: !paru (Rust) inof !pikaur
RUN --mount=type=cache,id=pacman-cache,target=/var/cache/pacman/pkg,sharing=locked \
    --mount=type=cache,id=cargo-cache,target=${myhome:?}/.cargo,uid=${myuid:?},gid=${mygid:?},sharing=locked \
    --mount=type=tmpfs,target=/tmp \
<<"EOF"
  touch "${myhome:?}/.hushlogin"
  cd /tmp
  # FAIL: paru: error while loading shared libraries: libalpm.so.15: cannot open shared object file: No such file or directory
  #   << latest pacman provides .so.16
  # git clone --depth=1 https://aur.archlinux.org/paru-bin.git
  ## DISABLED:PERF: building it takes takes >5min
  # sudo pacman -S --noconfirm --needed -- cargo
  # git clone --depth=1 https://aur.archlinux.org/paru.git
  # cd paru
  # ALT: curl -L https://aur.archlinux.org/cgit/aur.git/snapshot/pikaur.tar.gz | tar -xz
  git clone --depth=1 https://aur.archlinux.org/pikaur.git
  cd pikaur
  makepkg --syncdeps --clean --install --noconfirm --force  # PKGBUILD --rmdeps --skippgpcheck
  # ALT: sudo pacman -U --noconfirm paru*.pkg.tar.zst
EOF


